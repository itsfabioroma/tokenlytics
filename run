#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PORT="${PORT:-6969}"

if ! command -v cargo >/dev/null 2>&1; then
  echo "Tokenlytics needs Rust/Cargo. Install Rust from https://rustup.rs and run ./run again." >&2
  exit 1
fi

cd "$ROOT_DIR"
exec env PORT="$PORT" cargo run --quiet -- "$@"
